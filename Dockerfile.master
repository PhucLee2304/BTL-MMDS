COPY hadoop-3.3.6.tar.gz /tmp/
RUN tar -xzf /tmp/hadoop-3.3.6.tar.gz -C /opt/ \
    && mv /opt/hadoop-3.3.6 ${HADOOP_HOME} \
    && rm /tmp/hadoop-3.3.6.tar.gz

