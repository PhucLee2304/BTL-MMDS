COPY spark-3.5.0-bin-hadoop3.tgz /tmp/
RUN tar -xzf /tmp/spark-3.5.0-bin-hadoop3.tgz -C /opt/ \
    && mv /opt/spark-3.5.0-bin-hadoop3 ${SPARK_HOME} \
    && rm /tmp/spark-3.5.0-bin-hadoop3.tgz

