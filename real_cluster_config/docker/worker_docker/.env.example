# Worker node LAN configuration
# MASTER_HOST: IP of the master machine
# WORKER_HOST_IP: THIS machine's LAN IP (used for DataNode advertisement to clients)
# WORKER_DN_PORT: Unique DataNode transfer port for THIS worker (MUST be different per machine!)
#   - Worker on 192.168.1.112: use 9872
#   - Worker on 192.168.1.113: use 9882
#   - Worker on 192.168.1.114: use 9892
# WORKER_DN_IPC_PORT: = WORKER_DN_PORT + 1  (auto-calculated in entrypoint)
# WORKER_DN_HTTP_PORT: = WORKER_DN_PORT + 2 (auto-calculated in entrypoint)

# Example for worker on 192.168.1.112:
MASTER_HOST=192.168.1.111
WORKER_HOST_IP=192.168.1.112
WORKER_DN_PORT=9872
WORKER_DN_IPC_PORT=9873
WORKER_DN_HTTP_PORT=9874
